{
  "compilerOptions": {
    /* 基础 */
    "target": "esnext",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",

    /* 严格模式（建议开启） */
    "strict": true,

    /* Node 环境 */
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* 调试体验 */
    "sourceMap": true,

    /* 输出控制 */
    "removeComments": true,
    "skipLibCheck": true,

    /* 类型 */
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}